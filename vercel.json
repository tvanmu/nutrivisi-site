{
  "trailingSlash": false,
  "cleanUrls": true,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; base-uri 'self'; object-src 'none'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self'; form-action 'self'; frame-ancestors 'none'; upgrade-insecure-requests"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), payment=(), usb=(), accelerometer=(), gyroscope=(), magnetometer=()"
        },
        {
          "key": "X-Permitted-Cross-Domain-Policies",
          "value": "none"
        }
      ]
    }
  ],
  "redirects": [
    { "source": "/", "has": [{ "type": "host", "value": "www.nutrivisi.be" }], "destination": "https://nutrivisi.be", "permanent": true },
    { "source": "/:path*", "has": [{ "type": "host", "value": "www.nutrivisi.be" }], "destination": "https://nutrivisi.be/:path*", "permanent": true },
    { "source": "/en",        "destination": "/nl", "permanent": true },
    { "source": "/en/:path*", "destination": "/nl", "permanent": true }
  ],
  "rewrites": [
    { "source": "/((?!api/|_next/|assets/|.*\\..*).*)", "destination": "/" }
  ]
}
