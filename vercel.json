{
  "redirects": [
    {
      "source": "/nl/(.*)",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/fr/(.*)",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/over-ons/(.*)",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/diensten/(.*)",
      "destination": "/",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ]
}